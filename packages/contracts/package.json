{
  "name": "@very-prince/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "PayoutRegistry — Soroban smart contract for multi-organization maintenance payouts.",
  "license": "MIT",
  "scripts": {
    "build": "cargo build --target wasm32-unknown-unknown --release",
    "build:debug": "cargo build --target wasm32-unknown-unknown",
    "optimize": "stellar contract optimize --wasm target/wasm32-unknown-unknown/release/very_prince_contracts.wasm",
    "test": "cargo test",
    "test:snapshot": "SNAPSHOT_TEST=1 cargo test",
    "lint": "cargo clippy -- -D warnings",
    "format": "cargo fmt",
    "deploy": "bash scripts/deploy.sh",
    "deploy:local": "bash scripts/deploy-local.sh",
    "deploy:local:teardown": "bash scripts/deploy-local.sh --teardown"
  }
}
